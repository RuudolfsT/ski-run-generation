      <Option name="id" value="native:reprojectlayer_1" type="QString"/>
      <Option name="outputs"/>
      <Option name="outputs_collapsed" value="true" type="bool"/>
      <Option name="parameters_collapsed" value="true" type="bool"/>
      <Option name="params" type="Map">
        <Option name="CONVERT_CURVED_GEOMETRIES" type="List">
          <Option type="Map">
            <Option name="source" value="2" type="int"/>
            <Option name="static_value" value="false" type="bool"/>
          </Option>
        </Option>
        <Option name="INPUT" type="List">
          <Option type="Map">
            <Option name="child_id" value="quickosm:openosmfile_1" type="QString"/>
            <Option name="output_name" value="OUTPUT_MULTIPOLYGONS" type="QString"/>
            <Option name="source" value="1" type="int"/>
          </Option>
        </Option>
        <Option name="OPERATION" type="List">
          <Option type="Map">
            <Option name="source" value="2" type="int"/>
            <Option name="static_value" type="invalid"/>
          </Option>
        </Option>
        <Option name="TARGET_CRS" type="List">
          <Option type="Map">
            <Option name="expression" value="'EPSG:' || (&#xa;  CASE &#xa;    WHEN y(transform(centroid(layer_property(@dem, 'extent')), layer_property(@dem, 'crs'), 'EPSG:4326')) >= 0 &#xa;    THEN 32600 &#xa;    ELSE 32700 &#xa;  END&#xa;  + &#xa;  floor((x(transform(centroid(layer_property(@dem, 'extent')), layer_property(@dem, 'crs'), 'EPSG:4326')) + 180) / 6) + 1&#xa;)" type="QString"/>
            <Option name="source" value="3" type="int"/>
          </Option>
        </Option>
      </Option>
    </Option>
