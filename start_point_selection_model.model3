          <Option type="Map">
            <Option name="expression" value="'EPSG:' || (&#xa;  CASE &#xa;    WHEN y(transform(centroid(layer_property(@dem, 'extent')), layer_property(@dem, 'crs'), 'EPSG:4326')) >= 0 &#xa;    THEN 32600 &#xa;    ELSE 32700 &#xa;  END&#xa;  + &#xa;  floor((x(transform(centroid(layer_property(@dem, 'extent')), layer_property(@dem, 'crs'), 'EPSG:4326')) + 180) / 6) + 1&#xa;)" type="QString"/>
